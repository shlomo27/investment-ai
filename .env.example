# ─── Application ────────────────────────────────────────────────────────────────
APP_NAME=InvestmentAI
DEBUG=false
ENVIRONMENT=production

# ─── Security ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# ─── Database ────────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=strongpassword123
POSTGRES_DB=investment_ai
# Used by backend (asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:strongpassword123@postgres:5432/investment_ai

# ─── Redis ────────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Anthropic / Claude ──────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Twitter / X API v2 ─────────────────────────────────────────────────────────
# Get from: https://developer.twitter.com/
TWITTER_BEARER_TOKEN=AAAA...
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ─── Reddit API ──────────────────────────────────────────────────────────────────
# Get from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# ─── News APIs ───────────────────────────────────────────────────────────────────
# NewsAPI: https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key

# Alpha Vantage: https://www.alphavantage.co/
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# ─── SMS - Twilio ─────────────────────────────────────────────────────────────────
# Get from: https://www.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ─── Email - SendGrid ────────────────────────────────────────────────────────────
# Get from: https://sendgrid.com/
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_FROM_EMAIL=noreply@investment-ai.com
SENDGRID_FROM_NAME=Investment AI

# ─── Firebase Push Notifications ─────────────────────────────────────────────────
# Download credentials from Firebase Console > Project Settings > Service Accounts
FIREBASE_CREDENTIALS_PATH=/app/secrets/firebase-credentials.json

# ─── Risk Management ─────────────────────────────────────────────────────────────
# Max single asset exposure as fraction (0.03 = 3%)
MAX_SINGLE_ASSET_EXPOSURE=0.03

# ─── Agent Configuration ─────────────────────────────────────────────────────────
# How often to scan the asset pool (seconds)
AGENT_SCAN_INTERVAL_SECONDS=300

# ─── Frontend ────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
